generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// ===============================
/// MODEL ANGGOTA / USER
/// ===============================
model anggota {
  id                Int                @id @default(autoincrement())
  nama              String?
  alamat            String?
  no_hp             String?
  role              String             @default("nasabah")
  pekerjaan         String?
  email             String             @unique
  password          String
  createdAt         DateTime           @default(now())
  status            String             @default("active")
  updatedAt         DateTime           @updatedAt
  isProfileComplete Boolean            @default(false)
  jenis_kelamin     String?
  tanggal_lahir     DateTime?
  foto_diri         String?
  nik               String?
  username          String?            @unique
  eventPeserta      EventPeserta[]
  notifikasi        Notifikasi[]
  peminjaman        Peminjaman[]
  riwayat           RiwayatTransaksi[]
  simpanans         Simpanan[]

  @@map("anggota")
}

/// ===============================
/// MODEL PEMINJAMAN
/// ===============================
model Peminjaman {
  id_peminjaman     Int                @id @default(autoincrement())
  id_anggota        Int
  tanggal_pengajuan DateTime           @default(now())
  status            String
  total_pinjaman    Int
  jangka_waktu      Int
  status_survey     String             @default("BELUM")
  detail            DetailPeminjaman[]
  jadwal            JadwalAngsuran[]
  jadwalSurvey      jadwalSurvey[]
  anggota           anggota            @relation(fields: [id_anggota], references: [id])

  @@index([id_anggota])
  @@map("peminjaman")
}

/// ===============================
/// DETAIL PEMINJAMAN
/// ===============================
model DetailPeminjaman {
  id_peminjamandetail Int        @id @default(autoincrement())
  id_peminjaman       Int
  nama                String
  jenis               String
  jumlah              Int
  nilai_perolehan     Int
  keterangan          String?
  jangka_waktu        Int
  foto_agunan         String?
  foto_surat          String?
  peminjaman          Peminjaman @relation(fields: [id_peminjaman], references: [id_peminjaman])

  @@index([id_peminjaman])
  @@map("detail_peminjaman")
}

/// ===============================
/// JADWAL ANGSURAN
/// ===============================
model JadwalAngsuran {
  id_jadwal        Int               @id @default(autoincrement())
  id_peminjaman    Int
  jatuh_tempo      DateTime
  jumlah_tagihan   Int
  status           String
  cicilan_ke       Int
  jumlah_cicilan   Int
  catatan          String?
  denda            Int?
  peminjaman       Peminjaman        @relation(fields: [id_peminjaman], references: [id_peminjaman])
  pembayaran       Pembayaran[]
  whatsappReminder WhatsAppReminder?

  @@index([id_peminjaman])
  @@map("jadwal_angsuran")
}

/// ===============================
/// WHATSAPP REMINDER ANGSURAN
/// ===============================
model WhatsAppReminder {
  id_reminder   Int            @id @default(autoincrement())
  id_jadwal     Int            @unique
  no_hp         String
  pesan         String         @db.Text
  jadwal_kirim  DateTime
  status        String         @default("PENDING")
  sent_at       DateTime?
  error_message String?        @db.Text
  created_at    DateTime       @default(now())
  updated_at    DateTime       @updatedAt
  jadwal        JadwalAngsuran @relation(fields: [id_jadwal], references: [id_jadwal])

  @@index([status, jadwal_kirim])
  @@map("whatsapp_reminder")
}

/// ===============================
/// PEMBAYARAN
/// ===============================
model Pembayaran {
  id_pembayaran Int            @id @default(autoincrement())
  tanggal_bayar DateTime       @default(now())
  jumlah        Int
  status        String
  metode_bayar  String
  bukti_bayar   String?
  catatan       String?
  id_jadwal     Int
  jadwal        JadwalAngsuran @relation(fields: [id_jadwal], references: [id_jadwal])

  @@index([id_jadwal])
  @@map("pembayaran")
}

/// ===============================
/// SIMPANAN
/// ===============================
model Simpanan {
  id_simpanan         Int                  @id @default(autoincrement())
  id_anggota          Int
  jenis_simpanan      String
  status              String               @default("BELUM_BAYAR")
  created_at          DateTime             @default(now())
  nominal             Int
  tanggal_tagihan     DateTime
  jangka_waktu        Int?
  target_dana         Int?
  terkumpul           Int                  @default(0)
  tujuan              String?
  pembayaran_simpanan PembayaranSimpanan[]
  anggota             anggota              @relation(fields: [id_anggota], references: [id])

  @@index([id_anggota])
  @@map("simpanan")
}

/// ===============================
/// PEMBAYARAN SIMPANAN
/// ===============================
model PembayaranSimpanan {
  id_pembayaran_simpanan Int      @id @default(autoincrement())
  id_simpanan            Int
  tanggal_bayar          DateTime @default(now())
  metode_bayar           String?
  bukti_bayar            String?
  nominal_bayar          Int
  status                 String   @default("MENUNGGU")
  catatan                String?
  bulan_ke               Int
  jenis_simpanan         String?
  simpanan               Simpanan @relation(fields: [id_simpanan], references: [id_simpanan])

  @@index([id_simpanan])
  @@map("pembayaran_simpanan")
}

/// ===============================
/// RIWAYAT TRANSAKSI
/// ===============================
model RiwayatTransaksi {
  id_riwayat      Int      @id @default(autoincrement())
  id_anggota      Int
  jenis_transaksi String
  nominal         Int
  tanggal         DateTime @default(now())
  keterangan      String?
  kategori        String?
  metode_bayar    String?
  bukti_bayar     String?
  ref_tabel       String?
  ref_id          Int?
  anggota         anggota  @relation(fields: [id_anggota], references: [id])

  @@index([id_anggota])
  @@map("riwayat_transaksi")
}

/// ===============================
/// NOTIFIKASI
/// ===============================
model Notifikasi {
  id_notifikasi    Int       @id @default(autoincrement())
  id_anggota       Int?
  isi_notifikasi   String
  url_tujuan       String?
  waktu_dibaca     DateTime?
  jenis_notifikasi String
  created_at       DateTime  @default(now())
  role_tujuan      String
  anggota          anggota?  @relation(fields: [id_anggota], references: [id])

  @@index([id_anggota])
  @@map("notifikasi")
}

/// ===============================
/// EVENT
/// ===============================
model Event {
  id_event        Int            @id @default(autoincrement())
  judul           String
  deskripsi_event String?        
  gambar_event    String?
  tanggal         DateTime
  lokasi          String
  status          String         @default("published")
  peserta         EventPeserta[]

  @@map("event")
}

/// ===============================
/// EVENT PESERTA
/// ===============================
model EventPeserta {
  id_event_peserta Int      @id @default(autoincrement())
  id_event         Int
  id_anggota       Int
  tanggal_daftar   DateTime @default(now())
  email            String
  nama             String
  anggota          anggota  @relation(fields: [id_anggota], references: [id])
  event            Event    @relation(fields: [id_event], references: [id_event])

  @@unique([id_event, id_anggota])
  @@index([id_anggota])
  @@index([id_event])
  @@map("event_peserta")
}

/// ===============================
/// ARTIKEL
/// ===============================
model Artikel {
  id_artikel       Int      @id @default(autoincrement())
  judul            String
  deskripsi_konten String?  
  gambar_konten    String?
  tanggal_publish  DateTime @default(now())
  status           String

  @@map("artikel")
}

/// ===============================
/// SIMULASI ANGSURAN
/// ===============================
model SimulasiCicilan {
  id                Int @id @default(autoincrement())
  jumlah_pinjaman   Int
  tenor             Int
  cicilan_per_bulan Int

  @@map("simulasi_cicilan")
}

model jadwalSurvey {
  id_survey      Int        @id @default(autoincrement())
  id_peminjaman  Int
  tanggal_survey DateTime
  lokasi         String?
  catatan        String?
  status         String     @default("TERJADWAL")
  created_at     DateTime   @default(now())
  updated_at     DateTime   @updatedAt
  peminjaman     Peminjaman @relation(fields: [id_peminjaman], references: [id_peminjaman])

  @@index([id_peminjaman])
  @@map("jadwal_survey")
}

model rekeningpembayaran {
  id_rekening Int      @id @default(autoincrement())
  nama_bank   String
  no_rekening String
  atas_nama   String
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
}

model surattemplate {
  id_surat   Int      @id @default(autoincrement())
  nama_file  String
  file_url   String
  created_at DateTime @default(now())
  updated_at DateTime
  kode       String   @unique
}
